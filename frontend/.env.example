# ── Configuración de la API ──────────────────────────────────────────────────
# La URL de tu backend en producción
VITE_API_URL=https://api.tu-dominio.com

# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Public Key de PRODUCCIÓN (NUNCA uses el Access Token aquí)
# Obtenida de: https://www.mercadopago.com.pe/developers/panel/app
# Sección: Producción > Credenciales de producción > Public Key
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_MERCADOPAGO_LOCALE=es-PE

# ── Google y Seguridad ───────────────────────────────────────────────────────
# Obtenido desde Google Cloud Console -> Pantalla de Configuración OAuth y Credenciales
VITE_GOOGLE_CLIENT_ID=tu_cliente_id_google.apps.googleusercontent.com


# ── Google AdSense ───────────────────────────────────────────────────────────
# Activar o desactivar anuncios (true/false).
VITE_ENABLE_ADS=true
# Tu ID de editor (Publisher ID) de AdSense. Lo encuentras en tu cuenta como pub-...
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXX
